# Backend environment variables.
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# --- Core ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Environment ---
# Set to "production" or "local". In production, Gemini is ALWAYS used.
APP_ENV=local

# --- LLM Provider (only respected when APP_ENV=local) ---
# "gemini" = use Google Gemini (default)
# "ollama" = use local Ollama instance
LLM_PROVIDER=gemini

# --- Ollama (only used when LLM_PROVIDER=ollama and APP_ENV=local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
